# ── Supabase: point at your MAIN SMS project ─────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY   # SERVER SIDE ONLY
SCHOOL_ID=00000000-0000-0000-0000-000000000000

# ── Device auth ──────────────────────────────────────────────
# Bus devices / driver apps must send this as the X-Device-Key header.
DEVICE_API_KEY=set-a-long-random-secret

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8100
LOG_LEVEL=INFO
LOG_FORMAT=plain
