# ── Supabase: point at your MAIN SMS project ─────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# service_role key (Settings → API). SERVER SIDE ONLY — never ship to browser.
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY
# Which school this camera/kiosk belongs to (schools.id UUID)
SCHOOL_ID=00000000-0000-0000-0000-000000000000

# ── ML ───────────────────────────────────────────────────────
DEVICE=cpu                       # "cpu" or "cuda"
SCRFD_MODEL=buffalo_l
DETECTION_THRESHOLD=0.5
# Cosine similarity (0..1). Higher = stricter. 0.5 is a sensible start.
MATCH_SIMILARITY_THRESHOLD=0.5

# ── Attendance ───────────────────────────────────────────────
ATTENDANCE_DEDUP_MINUTES=5
DEFAULT_STATUS=present

# ── Camera ───────────────────────────────────────────────────
CAMERA_SOURCE=0                  # 0 = default webcam, or an rtsp:// URL for CCTV

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# REQUIRED for production: shared secret callers must send as X-Service-Key on
# /register and /recognize. If empty, those endpoints are UNAUTHENTICATED.
SERVICE_API_KEY=set-a-long-random-secret
# Browser origins allowed to call /register & /recognize (comma-separated).
# Default is local dev; set to your web app origin in production.
CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
LOG_FORMAT=plain

# In the WEB app (client/.env) set these so admins can enroll from the browser:
#   VITE_FACE_SERVICE_URL=http://localhost:8000
#   VITE_FACE_SERVICE_KEY=<same value as SERVICE_API_KEY above>
# NOTE: VITE_ vars are visible in the browser bundle — keep this service on a
# restricted/LAN network; the key is a guard, not a substitute for network isolation.
